# Copy this file to .env.local and fill in your keys.
# All vars are also set in Vercel dashboard under Project Settings > Environment Variables.

# Required for /api/digest and /api/studio (the morning digest + Signal Studio).
# Get one at https://console.anthropic.com — set a low budget cap.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Publishable token for img.logo.dev — powers the brand logos on
# the landing page. Free at https://www.logo.dev/dashboard (5000 reqs/mo).
# Safe to expose in the client bundle (that's what "pk_" means). If unset,
# logos fall back to inline SVG glyphs.
NEXT_PUBLIC_LOGO_DEV_TOKEN=pk_...

# Required. Gates /api/digest, /api/studio, /api/slack, /api/external-signals,
# and the refresh server action against random URL probing / bot crawlers.
# Any random string of 16+ chars. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, all gated routes return 500 (fail-closed).
DUGOUT_UI_SECRET=

# Required for the daily external-signals cron at /api/cron/external-signals.
# Vercel injects "Authorization: Bearer ${CRON_SECRET}" on its cron calls.
# If unset, the cron route refuses all requests.
CRON_SECRET=

# Required for the NewsAPI external-signals adapter.
# Free tier (100 req/day) is enough for the demo. https://newsapi.org/register
NEWSAPI_KEY=

# Required for the Firecrawl per-account scrape adapter.
# Used by /api/cron/firecrawl (daily 6am UTC): for each tracked account,
# scrapes a fixed set of content paths (homepage + /about + /news +
# /leadership) via POST https://api.firecrawl.dev/v2/scrape and stores
# raw markdown rows in `web_scrapes`. classify-pending sweeps those rows
# and emits external_signals with source="web_scrape".
#
# Get one at https://www.firecrawl.dev. ~44 calls/day (11 accounts × 4
# pages) at 1 credit each; ~1320/month. Cron route returns 500 if unset.
FIRECRAWL_API_KEY=fc-...

# Optional. If unset, /api/slack returns a preview payload instead of posting.
# Create one in your Slack workspace: Apps > Incoming Webhooks > Add to Channel.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Supabase — auto-injected by the Vercel-Supabase integration. Listed for
# reference. SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are the two that the
# external-signals code actually reads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === AgentMail (inbound newsletters) ===
#
# Newsletter inbox provider — https://agentmail.to. AgentMail uses Svix to
# deliver webhooks. Each registered endpoint in the AgentMail console
# (https://console.agentmail.to → Webhooks) gets its own signing secret.
# The svix library verifies signatures against the three svix-* request
# headers in one call.
#
# Setup:
#   1. Provision an inbox. Either click through the AgentMail console, or
#      run `npx tsx scripts/provision-agentmail-inbox.ts --local dugout`
#      (uses AGENTMAIL_API_KEY below).
#   2. Webhooks → Create Webhook → URL =
#      https://<deployment>/api/inbound-email/agentmail,
#      events = message.received (the .spam / .blocked / .unauthenticated
#      variants are also accepted by the route in case AgentMail flags
#      something — INBOUND_SENDER_ALLOWLIST below is the second line of
#      defense).
#   3. Copy the whsec_... secret from the webhook detail view into
#      AGENTMAIL_WEBHOOK_SECRET.
#   4. Subscribe newsletters from the inbox address; add their sending
#      domains to INBOUND_SENDER_ALLOWLIST.

# Svix shared secret for the inbound webhook endpoint, starts with `whsec_`.
# Pulled from AgentMail console → Webhooks → <endpoint> → Signing Secret.
# Must be 16+ chars (fail-closed below that). The route returns 500 if unset
# so the misconfiguration shows up in the AgentMail console's delivery logs.
AGENTMAIL_WEBHOOK_SECRET=whsec_...

# AgentMail REST API key (starts with `am_us_...` or similar region prefix).
# Server-side only — used by scripts/provision-agentmail-inbox.ts, the
# admin backfill route, AND the inbound webhook handler's body-fetch
# fallback (when the webhook payload arrives without inline text/html, the
# handler GETs the full message from the REST API to recover the body
# before Stage 1 would reject it as body_chars=0). Get one at
# console.agentmail.to → API Keys.
AGENTMAIL_API_KEY=am_us_...

# Inbox address Dugout receives newsletters into (e.g. dugout@agentmail.to).
# Optional — only used by the inbound webhook handler's body-fetch fallback
# above. When unset, the fallback tries to derive the inbox from the
# webhook payload's `to` field; setting this explicitly is more reliable.
AGENTMAIL_INBOX_ID=dugout@agentmail.to

# Comma-separated allowlist of sender domains (e.g. substack.com,beehiiv.com).
# Inbound mail from a domain not on this list — or a subdomain of one — is
# dropped silently with a 200 OK so AgentMail doesn't retry. Defense in depth
# on top of AgentMail's inbox routing: you control which newsletters were
# subscribed, but a misrouted personal email or a forwarded message shouldn't
# end up in the workspace knowledge base.
#
# FAIL CLOSED: an empty value rejects ALL inbound mail. This is the
# documented behavior (see senderAllowed() in src/lib/inbound-pipeline.ts).
# Example: substack.com,beehiiv.com,tldrnewsletter.com,lennysnewsletter.com
INBOUND_SENDER_ALLOWLIST=

# Sentinel account_id used for workspace-scoped newsletter signals (signals
# that didn't resolve to a tracked account — general market intel). Read by
# src/lib/external-signals.ts as WORKSPACE_ACCOUNT_ID; the morning digest
# joins on this value to surface a "Market intel" section. Currently hard-
# coded to "__workspace__" in code; this env entry exists so an operator
# can override per-environment without a code change if naming ever
# collides with a real account id.
WORKSPACE_ACCOUNT_ID=__workspace__

# === Dugout CLI skill (.claude/skills/firecrawl-company-scope) ===
# DUGOUT_SKILL_TOKEN=dskt_...
# Bearer token for the Claude Code skill to call /api/firecrawl/company-scope
# and /api/accounts/lookup without a UI session cookie. Used by AEs invoking
# /firecrawl-company-scope from the CLI before a meeting.
# Generate a random 32-byte hex string: `openssl rand -hex 32`.
# If unset, the skill will not work — both endpoints will require a UI
# session cookie (existing behavior preserved).
